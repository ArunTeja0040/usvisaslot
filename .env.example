# === Telegram Bot Token (shared across all users) ===
TELEGRAM_BOT_TOKEN=your_bot_token_here

# === Website URL ===
BASE_URL=https://www.usvisascheduling.com

# === Scheduling Behavior ===
# Slot polling interval — re-checks every 10-15 sec WITHOUT refreshing the page
POLL_DELAY_MIN=10
POLL_DELAY_MAX=15

# Delay between processing different users (seconds)
USER_SWITCH_DELAY_MIN=10
USER_SWITCH_DELAY_MAX=30

# Headless browser mode (true/false) — set false for debugging
HEADLESS=true

# CAPTCHA mode: "auto" (local OCR), "2captcha" (paid API), or "manual" (solve in browser)
CAPTCHA_MODE=auto

# If using 2captcha for auto CAPTCHA solving
TWO_CAPTCHA_API_KEY=

# Time to wait for interview dates after OFC booking (minutes)
INTERVIEW_WAIT_MINUTES=30
# Interview polling also uses POLL_DELAY_MIN/MAX (10-15s) during the wait window
